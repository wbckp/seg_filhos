generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PARENT
}

model Profile {
  id       String  @id @db.Uuid // Referência para auth.users.id do Supabase
  name     String
  photoUrl String? @map("photo_url")
  role     Role    @default(PARENT)

  children  Child[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Child {
  id        String   @id @default(uuid()) @db.Uuid
  parentId  String   @map("parent_id") @db.Uuid
  name      String
  birthDate DateTime @map("birth_date") @db.Date
  photoUrl  String?  @map("photo_url")

  parent  Profile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  devices Device[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("children")
}

model Device {
  id             String    @id @default(uuid()) @db.Uuid
  childId        String    @map("child_id") @db.Uuid
  deviceUuid     String    @unique @map("device_uuid") // ID gerado no lado do app
  deviceName     String    @map("device_name")
  manufacturer   String?
  model          String?
  androidVersion String?   @map("android_version")
  appVersion     String?   @map("app_version")
  batteryLevel   Int?      @map("battery_level")
  isOnline       Boolean   @default(false) @map("is_online")
  lastSeen       DateTime? @map("last_seen")

  child         Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  settings      DeviceSetting?
  installedApps InstalledApp[]
  rules         Rule[]
  appUsageLogs  AppUsageLog[]
  websiteLogs   WebsiteLog[]
  locationLogs  LocationLog[]
  alerts        Alert[]
  syncQueues    SyncQueue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("devices")
}

model DeviceSetting {
  id                          String    @id @default(uuid()) @db.Uuid
  deviceId                    String    @unique @map("device_id") @db.Uuid
  accessibilityEnabled        Boolean   @default(false) @map("accessibility_enabled")
  usagePermission             Boolean   @default(false) @map("usage_permission")
  overlayPermission           Boolean   @default(false) @map("overlay_permission")
  vpnPermission               Boolean   @default(false) @map("vpn_permission")
  locationPermission          Boolean   @default(false) @map("location_permission")
  batteryOptimizationDisabled Boolean   @default(false) @map("battery_optimization_disabled")
  lastSync                    DateTime? @map("last_sync")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_settings")
}

model InstalledApp {
  id          String  @id @default(uuid()) @db.Uuid
  deviceId    String  @map("device_id") @db.Uuid
  packageName String  @map("package_name")
  appName     String  @map("app_name")
  version     String?
  icon        String?
  isSystem    Boolean @default(false) @map("is_system")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([deviceId, packageName])
  @@map("installed_apps")
}

enum RuleType {
  APP
  SITE
  CATEGORY
}

enum RuleAction {
  BLOCK
  ALLOW
  LIMIT
}

model Rule {
  id                String     @id @default(uuid()) @db.Uuid
  deviceId          String     @map("device_id") @db.Uuid
  type              RuleType
  target            String // com.instagram.android, youtube.com, games, etc.
  action            RuleAction
  dailyLimitMinutes Int?       @map("daily_limit_minutes")
  enabled           Boolean    @default(true)

  device    Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  schedules Schedule[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("rules")
}

model Schedule {
  id        String  @id @default(uuid()) @db.Uuid
  ruleId    String  @map("rule_id") @db.Uuid
  weekday   Int // 0 = Sunday, 1 = Monday, etc.
  startTime String  @map("start_time") // HH:mm format
  endTime   String  @map("end_time") // HH:mm format
  enabled   Boolean @default(true)

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model AppUsageLog {
  id              String   @id @default(uuid()) @db.Uuid
  deviceId        String   @map("device_id") @db.Uuid
  packageName     String   @map("package_name")
  appName         String   @map("app_name")
  startedAt       DateTime @map("started_at")
  endedAt         DateTime @map("ended_at")
  durationSeconds Int      @map("duration_seconds")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("app_usage_logs")
}

model WebsiteLog {
  id         String   @id @default(uuid()) @db.Uuid
  deviceId   String   @map("device_id") @db.Uuid
  url        String
  domain     String
  title      String?
  blocked    Boolean  @default(false)
  accessedAt DateTime @default(now()) @map("accessed_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("website_logs")
}

model LocationLog {
  id        String @id @default(uuid()) @db.Uuid
  deviceId  String @map("device_id") @db.Uuid
  latitude  Float
  longitude Float
  accuracy  Float?
  speed     Float?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("location_logs")
}

enum AlertType {
  APP_INSTALLED
  APP_REMOVED
  BLOCKED_APP
  BLOCKED_SITE
  LOCATION_CHANGED
  PERMISSION_REVOKED
  VPN_DISABLED
  ACCESSIBILITY_DISABLED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id          String        @id @default(uuid()) @db.Uuid
  deviceId    String        @map("device_id") @db.Uuid
  type        AlertType
  severity    AlertSeverity @default(INFO)
  title       String
  description String?
  read        Boolean       @default(false)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("alerts")
}

model AuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String  @map("user_id") @db.Uuid // Reference to Profile
  action     String
  resource   String
  resourceId String? @map("resource_id")
  ip         String?
  userAgent  String? @map("user_agent")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum SyncStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model SyncQueue {
  id         String     @id @default(uuid()) @db.Uuid
  deviceId   String     @map("device_id") @db.Uuid
  payload    Json
  status     SyncStatus @default(PENDING)
  retryCount Int        @default(0) @map("retry_count")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("sync_queue")
}
